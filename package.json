{
  "name": "mahikeng-civic-safety",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Mahikeng Civic Issue Reporting & Community Safety PWA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "mobile:build": "JAVA_HOME=\"C:/Program Files/Android/Android Studio/jbr\" vite build && npx cap copy",
    "mobile:android": "JAVA_HOME=\"C:/Program Files/Android/Android Studio/jbr\" vite build && npx cap copy android && npx cap open android",
    "mobile:ios": "vite build && npx cap copy ios && npx cap open ios",
    "mobile:sync": "npx cap sync",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/local-notifications": "^8.2.0",
    "@supabase/supabase-js": "^2.106.1",
    "date-fns": "^3.0.0",
    "idb": "^8.0.0",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "localtunnel": "^2.0.2",
    "playwright": "^1.60.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^6.0.3",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "vitest": "^4.1.7",
    "workbox-window": "^7.0.0"
  }

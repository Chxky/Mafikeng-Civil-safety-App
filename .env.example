# Supabase Configuration (REQUIRED for live mode)
# Get these from: https://supabase.com/dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Africa's Talking SMS Gateway (needed for real SMS/USSD)
# Sign up at: https://africastalking.com/
VITE_AT_API_KEY=your-africastalking-api-key
VITE_AT_USERNAME=your-africastalking-username
VITE_AT_SENDER_ID=your-sender-id

# Web Push Notifications (needed for push notifications)
# Generate VAPID keys: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VITE_VAPID_PRIVATE_KEY=your-vapid-private-key

# EskomSePush API (optional — mock data used when not set)
# Sign up free at: https://developer.eskom.sepush.co.za/
VITE_ESP_API_KEY=your-eskomsepush-api-key

# AfriGIS Weather Warnings API (SAWS data feed — mock when not set)
# Sign up at: https://www.afrigis.co.za/
VITE_AFRIGIS_API_KEY=your-afrigis-api-key
